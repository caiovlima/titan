{
  "name": "titan",
  "version": "0.2.0",
  "description": "Enterprise Angular SSR Template",
  "repository": {
    "type": "git",
    "url": "https://github.com/caiovlima/titan.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration=local",
    "build": "ng build",
    "build:dev": "ng build --configuration development",
    "build:hml": "ng build --configuration hml",
    "build:prod": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "api:generate": "orval",
    "clean:modules": "node scripts/clean-modules.mjs",
    "reinstall": "node scripts/clean-modules.mjs && npm ci",
    "serve:ssr:titan": "node dist/titan/server/server.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,html,scss}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "private": true,
  "packageManager": "npm@11.13.0",
  "dependencies": {
    "@angular/cdk": "^21.2.12",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/platform-browser-dynamic": "^21.2.14",
    "@angular/platform-server": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@angular/ssr": "^21.2.12",
    "@lucide/angular": "^1.16.0",
    "@spartan-ng/brain": "^0.0.1-alpha.697",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "rxjs": "~7.8.0",
    "tailwind-merge": "^3.6.0",
    "tslib": "^2.3.0",
    "tw-animate-css": "^1.4.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/schematics": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.12",
    "@angular/cli": "^21.2.12",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@spartan-ng/cli": "^0.0.1-alpha.697",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/angular": "^19.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^5.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.17.19",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-preset-angular": "^16.1.5",
    "lint-staged": "^17.0.5",
    "msw": "^2.14.6",
    "orval": "^8.12.3",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.4"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
